APP_ENV=local
APP_SECRET_KEY=change-me

# Database connection (required for persistent config, snapshots, version log, chat history)
# Use either DATABASE_URL (generic) or SUPABASE_DB_URL (Supabase-specific).
# SUPABASE_DB_URL takes priority if both are set.
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.zoacexijvtesqwnsdmfy.supabase.co:5432/postgres
SUPABASE_DB_URL=

# Default display currency when no database config exists: NATIVE, EUR, or USD
DEFAULT_DISPLAY_CURRENCY=EUR

# Optional profile context used by GenAI prompts
INVESTOR_PROFILE=Long-term investor focused on diversified growth, moderate risk tolerance.
INVESTMENT_OBJECTIVES=Capital appreciation, diversification, periodic portfolio review.
RISK_TOLERANCE=moderate
INVESTMENT_HORIZON=10+ years

# Binance API. Use read-only keys only. Secret is required for account balances.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_BASE_URL=https://api.binance.com

# GenAI provider: google, openai, anthropic, or disabled
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GENAI_PROVIDER=google
GENAI_MODEL=gemini-1.5-flash

# FX source
EXCHANGERATE_HOST_URL=https://api.exchangerate.host
